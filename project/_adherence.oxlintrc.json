{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "apps/roastmyride-app/**",
              "apps/roastmyride-web/**",
              "components/cast/**",
              "components/core/**",
              "components/feedback/**",
              "components/mascot/**",
              "components/share/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Baloo 2|Hanken Grotesque))/i]",
        "message": "Font not provided by the design system. Available: Baloo 2, Hanken Grotesque."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:ember|flame|success|info|cool|pink|ink)$/]",
        "message": "<Badge> tone must be one of 'ember' | 'flame' | 'success' | 'info' | 'cool' | 'pink' | 'ink'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|block|disabled|iconLeft|iconRight|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, block, disabled, iconLeft, iconRight, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|accent|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'accent' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:sticker|stickerCorner|pad|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: sticker, stickerCorner, pad, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='stickerCorner'] > Literal[value!=/^(?:tl|tr|bl|br)$/]",
        "message": "<Card> stickerCorner must be one of 'tl' | 'tr' | 'bl' | 'br'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CastPicker'] > JSXAttribute > JSXIdentifier[name!=/^(?:initialId|onChange|style|key|ref|className|style|children)$/]",
        "message": "<CastPicker> doesn't accept that prop. Declared props: initialId, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:selected|emoji|children|onToggle|style|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: selected, emoji, children, onToggle, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Confetti'] > JSXAttribute > JSXIdentifier[name!=/^(?:count|active|style|key|ref|className|style|children)$/]",
        "message": "<Confetti> doesn't accept that prop. Declared props: count, active, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CreditTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:credits|price|perRoast|best|selected|onSelect|style|key|ref|className|style|children)$/]",
        "message": "<CreditTile> doesn't accept that prop. Declared props: credits, price, perRoast, best, selected, onSelect, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|iconLeft|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, error, iconLeft."
      },
      {
        "selector": "JSXOpeningElement[name.name='Mascot'] > JSXAttribute > JSXIdentifier[name!=/^(?:state|size|accessory|placeholderTag|reduceMotion|style|key|ref|className|style|children)$/]",
        "message": "<Mascot> doesn't accept that prop. Declared props: state, size, accessory, placeholderTag, reduceMotion, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Roaster'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|size|ring|style|key|ref|className|style|children)$/]",
        "message": "<Roaster> doesn't accept that prop. Declared props: id, size, ring, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Roaster'] > JSXAttribute[name.name='id'] > Literal[value!=/^(?:reginald|tony|abuomar|mama|mateo|jeanluc|priya|kenji)$/]",
        "message": "<Roaster> id must be one of 'reginald' | 'tony' | 'abuomar' | 'mama' | 'mateo' | 'jeanluc' | 'priya' | 'kenji'."
      },
      {
        "selector": "JSXOpeningElement[name.name='RoastSegment'] > JSXAttribute > JSXIdentifier[name!=/^(?:text|punch|key|ref|className|style|children)$/]",
        "message": "<RoastSegment> doesn't accept that prop. Declared props: text, punch."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sheet'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|title|header|onClose|primaryAction|children|style|key|ref|className|style|children)$/]",
        "message": "<Sheet> doesn't accept that prop. Declared props: open, title, header, onClose, primaryAction, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|icon|children|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: tone, icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:ink|success|danger|flame)$/]",
        "message": "<Toast> tone must be one of 'ink' | 'success' | 'danger' | 'flame'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
