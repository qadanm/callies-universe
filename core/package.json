{
  "name": "@callies-universe/core",
  "version": "0.1.0",
  "description": "Callie's Universe shared core: design tokens, component library, Callie's 9-state mascot system, and the character cast. Depends on nothing; every app extends it.",
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "tokens",
    "styles.css",
    "types"
  ],
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./styles.css",
    "./tokens/*": "./tokens/*"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./types/index.d.ts",
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
