# RoastMyRide — environment. Copy to .env and fill in. Everything works WITHOUT
# these (offline brain, silent voice, faux bg, mock payments, anonymous identity);
# fill them in to go live. Server vars live on the API host; VITE_* are build-time
# (inlined into the web app).

# ── Brain (server-side live comedy) ────────────────────────────────────────────
ANTHROPIC_API_KEY=
# BRAIN_WRITE_MODEL=claude-sonnet-4-6
# BRAIN_MODEL=claude-haiku-4-5

# ── Voice (ElevenLabs) — per-character voice ids (see services/voice/VOICE-DESIGN-PROMPTS.md)
ELEVENLABS_API_KEY=
VOICE_DEFAULT_ID=
VOICE_REGINALD_ID=
VOICE_TONY_ID=
VOICE_ABUOMAR_ID=
VOICE_MAMA_ID=
VOICE_MATEO_ID=
VOICE_JEANLUC_ID=
VOICE_PRIYA_ID=
VOICE_KENJI_ID=

# ── Render (Remotion) ──────────────────────────────────────────────────────────
CHROMIUM_BIN=/usr/bin/chromium
ROAST_REMOTION_ENTRY=/app/apps/roastmyride-app/remotion/index.jsx
ROAST_RENDER_SCALE=1
# ROAST_STORAGE=local            # local (default) | s3 (documented seam)

# ── API / server ───────────────────────────────────────────────────────────────
PORT=8787
ROAST_PUBLIC_URL=https://roastmyride.example
ROAST_FREE_CREDITS=3
ROAST_LEDGER_FILE=/data/ledger.json
# ROAST_RATE_MAX=60              # requests/min per identity
# ROAST_COST_MAX=60             # roasts+renders/hour per identity

# ── Payments (Stripe) ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Observability ──────────────────────────────────────────────────────────────
# SENTRY_DSN=

# ── Web app (build-time, Vite) ───────────────────────────────────────────────────
VITE_ROAST_API=                 # your services/api origin, e.g. https://roastmyride-api.fly.dev
VITE_PURCHASES_PROVIDER=        # stripe  (empty = mock)
VITE_AUTH_PROVIDER=             # supabase (empty = anonymous device id)
